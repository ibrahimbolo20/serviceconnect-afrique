generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String    @unique
  password      String
  role          String    @default("CLIENT")
  name          String
  avatar        String?
  city          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  clientBookings   Booking[] @relation("ClientBookings")
  providerProfile  Provider?
  reviews          Review[]  @relation("ReviewClient")
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  payments         Payment[]
}

model Provider {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id])

  category          String
  specialties       String   // JSON string example: "plomberie,électricité"
  hourlyRate        Int
  description       String
  idDocumentUrl     String?
  idDocumentBackUrl String?
  idDocumentStatus  String   @default("PENDING")
  verified          Boolean  @default(false)
  isAvailable       Boolean  @default(true)
  walletBalance     Float    @default(0)
  withdrawnTotal    Float    @default(0)

  bookings          Booking[] @relation("ProviderBookings")
  reviews           Review[]  @relation("ReviewProvider")
}

model Booking {
  id              String   @id @default(cuid())
  clientId        String
  providerId      String

  client          User     @relation("ClientBookings", fields: [clientId], references: [id])
  provider        Provider @relation("ProviderBookings", fields: [providerId], references: [id])

  date            String
  time            String
  description     String
  status          String   @default("PENDING")
  paymentStatus   String   @default("UNPAID")
  amount          Int
  commissionAmount Int

  ratingLeft      Int?
  reviewLeft      String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Review {
  id          String   @id @default(cuid())
  clientId    String
  providerId  String
  rating      Int
  comment     String
  createdAt   DateTime @default(now())

  client      User     @relation("ReviewClient", fields: [clientId], references: [id])
  provider    Provider @relation("ReviewProvider", fields: [providerId], references: [id])
}

model Payment {
  id            String   @id @default(cuid())
  bookingId     String?
  userId        String
  amount        Int
  method        String
  phone         String
  status        String
  transactionId String?
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])
}

model Message {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  content     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
}